FROM python:3.12-slim

WORKDIR /app

# Install dependencies (pipeline needs pandas, holidays, requests — no anthropic needed)
COPY requirements.txt .
RUN pip install --no-cache-dir pandas numpy holidays requests

# Copy pipeline code
COPY config.py .
COPY pipeline/ pipeline/

# Create data directory
RUN mkdir -p data

# Pipeline writes output to /app/data/ — mount Azure Blob or shared volume
CMD ["python", "pipeline/run_analytics.py"]
