FROM python:3.12-slim

WORKDIR /app

# Pipeline dependencies (no anthropic needed)
COPY requirements.pipeline.txt .
RUN pip install --no-cache-dir -r requirements.pipeline.txt

# Copy pipeline code
COPY config.py .
COPY pipeline/ pipeline/

# Create data directory (mount shared volume here)
RUN mkdir -p data

# Ensure bare imports in pipeline/ resolve correctly
ENV PYTHONPATH="/app/pipeline:/app"

CMD ["python", "pipeline/run_analytics.py"]
